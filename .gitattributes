* text=auto

# SQL files should always use LF
*.sql text eol=lf

# JavaScript/TypeScript - LF
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf

# YAML/Config - LF
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Markdown - LF
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
